{
  "name": "vscode-footnote-highlight",
  "displayName": "APL Inspector",
  "description": "页面辅助检查面板：HTML 脚注、ARIA labels、图片 ALT、Hidden/Visible 快速定位（像素风 APL）。",
  "version": "0.0.7",
  "publisher": "SimonGu",
  "license": "MIT",
  "homepage": "https://github.com/simongu-mullenlowe/vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/simongu-mullenlowe/vscode-extension/issues"
  },
  "keywords": [
    "footnote",
    "html",
    "accessibility",
    "aria-label",
    "alt",
    "visibility",
    "inspector"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/simongu-mullenlowe/vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:aplInspector.footnotes",
    "onView:aplInspector.ariaLabels",
    "onView:aplInspector.imageAlts",
    "onView:aplInspector.visibility"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aplInspector",
          "title": "APL",
          "icon": "media/footnote.svg"
        }
      ]
    },
    "views": {
      "aplInspector": [
        {
          "id": "aplInspector.footnotes",
          "name": "脚注列表",
          "contextualTitle": "脚注"
        },
        {
          "id": "aplInspector.ariaLabels",
          "name": "ARIA Labels",
          "contextualTitle": "ARIA"
        },
        {
          "id": "aplInspector.imageAlts",
          "name": "Image Alts",
          "contextualTitle": "ALT"
        },
        {
          "id": "aplInspector.visibility",
          "name": "Hidden / Visible",
          "contextualTitle": "Visibility"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.footnotes",
          "group": "navigation"
        },
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.ariaLabels",
          "group": "navigation"
        },
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.imageAlts",
          "group": "navigation"
        },
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.visibility",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "aplInspector.reveal",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "APL Inspector",
      "properties": {
        "aplInspector.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用 APL Inspector 的高亮与侧栏功能。"
        },
        "aplInspector.mode": {
          "type": "string",
          "enum": ["focus", "all"],
          "default": "focus",
          "description": "脚注高亮模式：focus=光标命中脚注时只高亮该组；all=高亮全部脚注。"
        }
      }
    },
    "commands": [
      {
        "command": "aplInspector.refresh",
        "title": "刷新",
        "category": "APL Inspector",
        "icon": "$(refresh)"
      },
      {
        "command": "aplInspector.reveal",
        "title": "跳转到脚注位置",
        "category": "APL Inspector"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "gen:icon": "node tools/gen_icon_png.mjs",
    "package": "npm run gen:icon && vsce package --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.3"
  }
}
