{
  "name": "vscode-footnote-highlight",
  "displayName": "APL Inspector",
  "description": "Sidebar inspector for footnotes, aria-label, image alt, and hidden/visible markers (APL pixel UI). 侧栏检查：脚注、ARIA、ALT、可见性。",
  "version": "0.0.9",
  "publisher": "SimonGu",
  "license": "MIT",
  "homepage": "https://github.com/simongu-mullenlowe/vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/simongu-mullenlowe/vscode-extension/issues"
  },
  "keywords": [
    "footnote",
    "html",
    "accessibility",
    "aria-label",
    "alt",
    "visibility",
    "inspector"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/simongu-mullenlowe/vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:aplInspector.footnotes",
    "onView:aplInspector.ariaLabels",
    "onView:aplInspector.imageAlts",
    "onView:aplInspector.visibility"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aplInspector",
          "title": "APL",
          "icon": "media/footnote.svg"
        }
      ]
    },
    "views": {
      "aplInspector": [
        {
          "id": "aplInspector.footnotes",
          "name": "脚注列表",
          "contextualTitle": "脚注"
        },
        {
          "id": "aplInspector.ariaLabels",
          "name": "ARIA Labels",
          "contextualTitle": "ARIA"
        },
        {
          "id": "aplInspector.imageAlts",
          "name": "Image Alts",
          "contextualTitle": "ALT"
        },
        {
          "id": "aplInspector.visibility",
          "name": "Hidden / Visible",
          "contextualTitle": "Visibility"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.footnotes",
          "group": "navigation"
        },
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.ariaLabels",
          "group": "navigation"
        },
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.imageAlts",
          "group": "navigation"
        },
        {
          "command": "aplInspector.refresh",
          "when": "view == aplInspector.visibility",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "aplInspector.reveal",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "APL Inspector",
      "properties": {
        "aplInspector.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable APL Inspector highlights and sidebar views. 是否启用高亮与侧栏。"
        },
        "aplInspector.mode": {
          "type": "string",
          "enum": ["focus", "all"],
          "default": "focus",
          "description": "Footnote highlight: focus = only the group under cursor; all = every footnote. 脚注高亮：focus 仅当前组，all 全文。"
        }
      }
    },
    "commands": [
      {
        "command": "aplInspector.refresh",
        "title": "刷新",
        "category": "APL Inspector",
        "icon": "$(refresh)"
      },
      {
        "command": "aplInspector.reveal",
        "title": "跳转到脚注位置",
        "category": "APL Inspector"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "gen:icon": "node tools/gen_icon_png.mjs",
    "package": "npm run compile && npm run gen:icon && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.3"
  }
}
